# OpenHands Configuration
# Copie para .env.openhands.local para overrides locais (não commitados)

# LLM via LiteLLM proxy local (localhost:4000)
OPENHANDS_LLM_API_KEY=sk-123456789
OPENHANDS_LLM_BASE_URL=http://host.containers.internal:4000/v1
OPENHANDS_LLM_MODEL=gpt-5.3-chat-latest

# GitHub token (opcional — necessário pra criar PRs)
# Gere em: https://github.com/settings/tokens
# OPENHANDS_GITHUB_TOKEN=ghp_...
