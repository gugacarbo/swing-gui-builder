{
  "version": "0.0.3",
  "name": "swing-gui-builder",
  "displayName": "Swing GUI Builder",
  "description": "Visual drag-and-drop GUI builder for Java Swing in VS Code",
  "publisher": "gugacarbo",
  "homepage": "https://github.com/gugacarbo/swing-gui-builder#readme",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gugacarbo/swing-gui-builder.git"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other",
    "Snippets"
  ],
  "keywords": [
    "java",
    "swing",
    "gui",
    "builder",
    "drag-and-drop",
    "visual",
    "code-generator",
    "ui-designer",
    "vscode-extension",
    "ui",
    "ui-builder"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "scripts": {
    "compile": "pnpm run build:shared && pnpm run build:webview && pnpm run build:extension",
    "build:extension": "tsc -p ./",
    "build:webview": "pnpm --dir webview-app build",
    "build:shared": "pnpm --dir shared build",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run compile",
    "lint": "biome check src && pnpm --dir shared lint && pnpm --dir webview-app lint",
    "lint:fix": "biome check --write src && pnpm --dir shared lint:fix && pnpm --dir webview-app lint:fix",
    "typecheck": "pnpm --dir shared typecheck && pnpm --dir webview-app typecheck && tsc -p ./ --noEmit",
    "vscode:prepublish": "pnpm run compile",
    "vsc:pkg": "vsce package",
    "vsc:push": "vsce publish"
  },
  "devDependencies": {
    "@shared/types": "workspace:*",
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "swingGuiBuilder.newWindow",
        "title": "Swing GUI Builder: New Window"
      },
      {
        "command": "swingGuiBuilder.generate",
        "title": "Swing GUI Builder: Generate"
      },
      {
        "command": "swingGuiBuilder.save",
        "title": "Swing GUI Builder: Save"
      },
      {
        "command": "swingGuiBuilder.open",
        "title": "Swing GUI Builder: Open"
      },
      {
        "command": "swingGuiBuilder.initConfig",
        "title": "Swing GUI Builder: Init Project Config"
      }
    ],
    "configuration": {
      "title": "Swing GUI Builder",
      "properties": {
        "swingGuiBuilder.defaultBackgroundColor": {
          "type": "string",
          "default": "#FFFFFF",
          "description": "Default background color for new components"
        },
        "swingGuiBuilder.defaultTextColor": {
          "type": "string",
          "default": "#000000",
          "description": "Default text color for new components"
        },
        "swingGuiBuilder.defaultFontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Default font family for new components"
        },
        "swingGuiBuilder.defaultFontSize": {
          "type": "number",
          "default": 12,
          "description": "Default font size for new components"
        },
        "swingGuiBuilder.outputDirectory": {
          "type": "string",
          "default": "swing/components/",
          "description": "Default output directory for generated Java files"
        },
        "swingGuiBuilder.components.Button.defaultBackgroundColor": {
          "type": "string",
          "default": "#FFFFFF",
          "description": "Default background color for Button components"
        },
        "swingGuiBuilder.components.Button.defaultTextColor": {
          "type": "string",
          "default": "#000000",
          "description": "Default text color for Button components"
        },
        "swingGuiBuilder.components.Button.defaultFontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Default font family for Button components"
        },
        "swingGuiBuilder.components.Button.defaultFontSize": {
          "type": "number",
          "default": 12,
          "description": "Default font size for Button components"
        },
        "swingGuiBuilder.components.Label.defaultBackgroundColor": {
          "type": "string",
          "default": "#FFFFFF",
          "description": "Default background color for Label components"
        },
        "swingGuiBuilder.components.Label.defaultTextColor": {
          "type": "string",
          "default": "#000000",
          "description": "Default text color for Label components"
        },
        "swingGuiBuilder.components.Label.defaultFontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Default font family for Label components"
        },
        "swingGuiBuilder.components.Label.defaultFontSize": {
          "type": "number",
          "default": 12,
          "description": "Default font size for Label components"
        },
        "swingGuiBuilder.components.TextField.defaultBackgroundColor": {
          "type": "string",
          "default": "#FFFFFF",
          "description": "Default background color for TextField components"
        },
        "swingGuiBuilder.components.TextField.defaultTextColor": {
          "type": "string",
          "default": "#000000",
          "description": "Default text color for TextField components"
        },
        "swingGuiBuilder.components.TextField.defaultFontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Default font family for TextField components"
        },
        "swingGuiBuilder.components.TextField.defaultFontSize": {
          "type": "number",
          "default": 12,
          "description": "Default font size for TextField components"
        },
        "swingGuiBuilder.components.PasswordField.defaultBackgroundColor": {
          "type": "string",
          "default": "#FFFFFF",
          "description": "Default background color for PasswordField components"
        },
        "swingGuiBuilder.components.PasswordField.defaultTextColor": {
          "type": "string",
          "default": "#000000",
          "description": "Default text color for PasswordField components"
        },
        "swingGuiBuilder.components.PasswordField.defaultFontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Default font family for PasswordField components"
        },
        "swingGuiBuilder.components.PasswordField.defaultFontSize": {
          "type": "number",
          "default": 12,
          "description": "Default font size for PasswordField components"
        },
        "swingGuiBuilder.components.TextArea.defaultBackgroundColor": {
          "type": "string",
          "default": "#FFFFFF",
          "description": "Default background color for TextArea components"
        },
        "swingGuiBuilder.components.TextArea.defaultTextColor": {
          "type": "string",
          "default": "#000000",
          "description": "Default text color for TextArea components"
        },
        "swingGuiBuilder.components.TextArea.defaultFontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Default font family for TextArea components"
        },
        "swingGuiBuilder.components.TextArea.defaultFontSize": {
          "type": "number",
          "default": 12,
          "description": "Default font size for TextArea components"
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.swingbuilder.json",
        "url": "./schemas/swingbuilder.schema.json"
      }
    ]
  }
}
